# Database
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/paisa-tracker?retryWrites=true&w=majority"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (Google Gemini)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-pro"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Paisa Tracker"
NODE_ENV="development"

# Email (Optional - for OTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@paisatracker.app"

# Cron Jobs (Enable in production)
ENABLE_CRON_JOBS="false"
